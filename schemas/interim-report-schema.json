{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanoss.com/schemas/interim-report.json",
  "title": "SCANOSS Crypto-Finder Interim Report",
  "description": "Standardized output format for cryptographic findings from SCANOSS crypto-finder scanners",
  "type": "object",
  "required": ["version", "tool", "findings"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the interim report schema (e.g., \"1.4\")",
      "examples": ["1.4", "1.3", "1.2", "1.1", "1.0"]
    },
    "tool": {
      "$ref": "#/$defs/ToolInfo"
    },
    "findings": {
      "type": "array",
      "description": "All detected cryptographic assets grouped by file",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    }
  },
  "$defs": {
    "ToolInfo": {
      "type": "object",
      "description": "Metadata about the scanner that produced the report",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the scanner tool",
          "examples": ["crypto-finder", "cbom-toolkit"]
        },
        "version": {
          "type": "string",
          "description": "Version of the scanner tool",
          "examples": ["1.45.0"]
        }
      }
    },
    "Finding": {
      "type": "object",
      "description": "All cryptographic assets discovered in a single file",
      "required": [
        "file_path",
        "language",
        "cryptographic_assets"
      ],
      "properties": {
        "file_path": {
          "type": "string",
          "description": "Path to the file containing cryptographic assets"
        },
        "language": {
          "type": "string",
          "description": "Programming language of the file",
          "examples": ["java", "python", "go", "javascript", "c", "cpp"]
        },
        "cryptographic_assets": {
          "type": "array",
          "description": "All cryptographic materials found in this file",
          "items": {
            "$ref": "#/$defs/CryptographicAsset"
          }
        }
      }
    },
    "CryptographicAsset": {
      "type": "object",
      "description": "A single detected cryptographic element",
      "required": [
        "start_line",
        "end_line",
        "match",
        "status",
        "metadata"
      ],
      "properties": {
        "start_line": {
          "type": "integer",
          "minimum": 1,
          "description": "First line number where the asset was detected"
        },
        "end_line": {
          "type": "integer",
          "minimum": 1,
          "description": "Last line number where the asset was detected"
        },
        "match": {
          "type": "string",
          "description": "Actual code snippet that was matched"
        },
        "rules": {
          "type": "array",
          "description": "Detection rules that identified this cryptographic asset (v1.1+)",
          "items": {
            "$ref": "#/$defs/RuleInfo"
          }
        },
        "rule": {
          "$ref": "#/$defs/RuleInfo",
          "description": "Single detection rule (deprecated, use 'rules' array in v1.1+)"
        },
        "status": {
          "type": "string",
          "description": "Current state of this finding",
          "examples": ["pending", "identified"]
        },
        "metadata": {
          "type": "object",
          "description": "Metadata extracted from the cryptographic asset (e.g., key length, algorithm)",
          "additionalProperties": {
            "type": "string"
          }
        },
        "source": {
          "type": "string",
          "description": "How this finding was discovered (v1.2+)",
          "enum": ["direct", "dependency"]
        },
        "dependency_info": {
          "$ref": "#/$defs/DependencyInfo",
          "description": "Attribution data when the finding originates from a dependency (v1.2+)"
        },
        "parameter_conditions": {
          "type": "array",
          "description": "Structured predicates parsed from metadata.parameterCondition (v1.4+). Absent when the rule carries no predicate.",
          "items": {
            "$ref": "#/$defs/ParameterCondition"
          }
        }
      },
      "oneOf": [
        {"required": ["rules"]},
        {"required": ["rule"]}
      ]
    },
    "DependencyInfo": {
      "type": "object",
      "description": "Attribution metadata for findings originating from dependencies",
      "required": ["module", "version"],
      "properties": {
        "module": {
          "type": "string",
          "description": "Dependency module path (e.g., \"golang.org/x/crypto\")"
        },
        "version": {
          "type": "string",
          "description": "Dependency version (e.g., \"v0.17.0\")"
        }
      }
    },
    "RuleInfo": {
      "type": "object",
      "description": "Information about the detection rule that identified the cryptographic asset",
      "required": ["id", "message", "severity"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the rule",
          "examples": [
            "java.crypto.javax.cipher-aes-ecb",
            "python.crypto.cryptography.key-generation"
          ],
          "pattern": "^[a-z0-9]+\\.[a-z0-9]+\\.[a-z0-9.-]+$"
        },
        "message": {
          "type": "string",
          "description": "Human-readable description of what was detected"
        },
        "severity": {
          "type": "string",
          "description": "Importance level of the finding",
          "examples": ["WARNING", "ERROR", "INFO"]
        }
      }
    },
    "ParameterCondition": {
      "type": "object",
      "description": "One parsed parameterCondition predicate (v1.4+): param[<selector>]<op><value>",
      "required": ["raw", "selector", "operator", "match", "value"],
      "properties": {
        "raw": {
          "type": "string",
          "description": "Exact source substring this condition was parsed from",
          "examples": ["param[0]==true", "param[1]:type==javax.crypto.SecretKey"]
        },
        "selector": {
          "$ref": "#/$defs/ParameterSelector"
        },
        "operator": {
          "type": "string",
          "description": "Comparison operator",
          "enum": ["==", "~="]
        },
        "match": {
          "type": "string",
          "description": "Whether the predicate compares the argument's value or its static type",
          "enum": ["value", "type"]
        },
        "value": {
          "type": "string",
          "description": "Comparison operand, taken verbatim from the source"
        }
      }
    },
    "ParameterSelector": {
      "type": "object",
      "description": "Identifies which call argument a predicate binds to (positional, keyword, or both)",
      "required": ["index", "name"],
      "properties": {
        "index": {
          "type": ["integer", "null"],
          "description": "0-based positional argument index; null when the selector is keyword-only"
        },
        "name": {
          "type": ["string", "null"],
          "description": "Keyword/parameter name; null when the selector is positional-only"
        }
      }
    }
  }
}
